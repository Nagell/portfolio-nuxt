{
    "installCommand": "pnpm install",
    "headers": [
        {
            "source": "/_ipx/(.*)",
            "headers": [
                { "key": "CDN-Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        }
    ],
    "git": {
        "deploymentEnabled": {
            "dev": false,
            "feature/tests": false
        }
    }
}