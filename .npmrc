# Hoist packages to node_modules/ so Vercel's Node File Tracer can resolve
# them at runtime (required by @nuxt/nitro-server renderer chunk)
public-hoist-pattern[]=vue
# Required by @nuxtjs/sitemap@8 and @nuxtjs/robots@6 at SSR runtime
public-hoist-pattern[]=nuxt-site-config
public-hoist-pattern[]=nuxtseo-shared
